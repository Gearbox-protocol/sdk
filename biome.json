{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "extends": ["@gearbox-protocol/biome-config"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!dist",
      "!tmp",
      "!website/build",
      "!website/.docusaurus"
    ],
    "ignoreUnknown": true
  },
  "linter": {
    "rules": {
      "correctness": {
        "useImportExtensions": {
          "level": "error",
          "options": {
            "forceJsExtensions": true
          }
        }
      }
    }
  }
}
