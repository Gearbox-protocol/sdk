{
  "branches": [
    {
      "name": "master"
    },
    {
      "name": "next",
      "channel": "next",
      "prerelease": "next"
    },
    {
      "name": "kyc",
      "channel": "kyc",
      "prerelease": "kyc"
    },
    {
      "name": "test",
      "channel": "test",
      "prerelease": true
    },
    {
      "name": "+([0-9])?(.{+([0-9]),x}).x"
    }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/npm",
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "failTitle": false
      }
    ]
  ]
}
